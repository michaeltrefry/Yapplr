# =============================================================================
# Yapplr Staging Environment Configuration
# =============================================================================
# Copy this file to .env.staging and fill in your actual values
# This file is used by docker-compose.staging.yml

# =============================================================================
# DATABASE CONFIGURATION (LOCAL POSTGRESQL)
# =============================================================================
# Note: PostgreSQL runs as a Docker container in staging
POSTGRES_DB=yapplr_staging
POSTGRES_USER=yapplr_staging_user
POSTGRES_PASSWORD=staging_db_password_change_me

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET_KEY=staging-jwt-key-that-should-be-at-least-32-characters-long
JWT_ISSUER=Yapplr.Api.Staging
JWT_AUDIENCE=Yapplr.Client.Staging

# =============================================================================
# EMAIL CONFIGURATION (SendGrid)
# =============================================================================
# SendGrid Configuration
SENDGRID_API_KEY=your-sendgrid-staging-api-key-here
SENDGRID_FROM_EMAIL=staging@yapplr.com
SENDGRID_FROM_NAME=Yapplr Staging
EMAIL_PROVIDER=SendGrid

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
API_BASE_URL=http://localhost
WS_BASE_URL=ws://localhost
FRONTEND_URL=http://localhost

# =============================================================================
# FIREBASE CONFIGURATION (for mobile push notifications)
# =============================================================================
FIREBASE_PROJECT_ID=your-firebase-staging-project-id

# Note: FIREBASE_SERVICE_ACCOUNT_KEY should be set as a file
# Create firebase-service-account.json with your service account key

# =============================================================================
# VIDEO PROCESSING CONFIGURATION
# =============================================================================
VIDEO_MAX_CONCURRENT_JOBS=1
VIDEO_POLL_INTERVAL=5
VIDEO_MAX_DURATION=300
VIDEO_MAX_SIZE=104857600
VIDEO_MAX_WIDTH=1280
VIDEO_MAX_HEIGHT=720
VIDEO_BITRATE=1000k
AUDIO_BITRATE=128k

# =============================================================================
# STAGING SPECIFIC NOTES
# =============================================================================
# 1. PostgreSQL runs locally in Docker (exposed on port 5432)
# 2. Use lower resource limits for video processing
# 3. Firebase project should be separate from production
# 4. Email settings can use test/development accounts
# 5. Domains are typically localhost or staging subdomains
# 6. Database data persists in Docker volume 'postgres_data'

# =============================================================================
# DATABASE ACCESS (for debugging/admin)
# =============================================================================
# You can connect to the staging database using:
# Host: localhost
# Port: 5432
# Database: yapplr_staging
# Username: yapplr_staging_user
# Password: staging_db_password_change_me

# =============================================================================
# SECURITY NOTES FOR STAGING
# =============================================================================
# 1. Use different credentials than production
# 2. JWT secret should be different from production
# 3. Use staging Firebase project
# 4. Email can use test accounts
# 5. Database is local but still use strong passwords
