# Yapplr Production Environment Configuration
# Copy this file to .env.production and fill in the values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=yapplr
POSTGRES_USER=yapplr_user
POSTGRES_PASSWORD=your_secure_database_password_here
DATABASE_CONNECTION_STRING=Host=postgres;Database=yapplr;Username=yapplr_user;Password=your_secure_database_password_here

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters
JWT_ISSUER=https://api.yapplr.com
JWT_AUDIENCE=https://yapplr.com

# =============================================================================
# EMAIL CONFIGURATION (SendGrid)
# =============================================================================
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
FROM_EMAIL=noreply@yapplr.com
FROM_NAME=Yapplr

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
API_BASE_URL=https://api.yapplr.com
WS_BASE_URL=wss://api.yapplr.com
FRONTEND_URL=https://yapplr.com

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# VIDEO PROCESSING CONFIGURATION
# =============================================================================
VIDEO_MAX_CONCURRENT_JOBS=2
VIDEO_POLL_INTERVAL=5
VIDEO_MAX_DURATION=300
VIDEO_MAX_SIZE=104857600
VIDEO_MAX_WIDTH=1920
VIDEO_MAX_HEIGHT=1080
VIDEO_BITRATE=2000k
AUDIO_BITRATE=128k

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
GRAFANA_PASSWORD=your_grafana_admin_password_here

# =============================================================================
# SSL CONFIGURATION
# =============================================================================
# Place your SSL certificates in nginx/ssl/
# SSL_CERT_PATH=nginx/ssl/yapplr.com.crt
# SSL_KEY_PATH=nginx/ssl/yapplr.com.key

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=yapplr-backups
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# =============================================================================
# NOTIFICATION CONFIGURATION (Optional)
# =============================================================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_CLIENT_ID=your_firebase_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate secure random passwords for production
# Use: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here
API_RATE_LIMIT=100
UPLOAD_RATE_LIMIT=10

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=Information
SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30
QUERY_TIMEOUT=30
