{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=yapplr;Username=postgres;Password=password"
  },
  "VideoProcessing": {
    "InputPath": "../uploads/videos",
    "OutputPath": "../uploads/videos",
    "ThumbnailPath": "../uploads/thumbnails",
    "TempPath": "../uploads/temp",
    "MaxConcurrentJobs": 2,
    "PollIntervalSeconds": 5,
    "FFmpegPath": "ffmpeg",
    "FFprobePath": "ffprobe",
    "DefaultQuality": {
      "VideoCodec": "libx264",
      "AudioCodec": "aac",
      "VideoBitrate": "1000k",
      "AudioBitrate": "128k",
      "MaxWidth": 1280,
      "MaxHeight": 720,
      "FrameRate": 30
    },
    "ThumbnailSettings": {
      "Width": 320,
      "Height": 180,
      "Quality": 85,
      "TimeOffset": "00:00:01"
    },
    "SupportedFormats": {
      "Input": [".mp4", ".webm", ".mov", ".avi", ".mkv"],
      "Output": [".mp4", ".webm"]
    },
    "Limits": {
      "MaxDurationSeconds": 300,
      "MaxFileSizeBytes": 104857600
    }
  }
}
